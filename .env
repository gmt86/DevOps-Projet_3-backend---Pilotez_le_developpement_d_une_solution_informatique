POSTGRES_DB=datashare
POSTGRES_USER=datashare_user
POSTGRES_PASSWORD=datashare_password
POSTGRES_PORT=5432
# Clé secrète utilisée pour signer les tokens JWT
JWT_SECRET=datashare_secret_key_very_long_and_secure_2026
# Durée de validité du token en millisecondes (86400000 = 24 heures)
JWT_EXPIRATION=86400000
# Chemin de stockage des fichiers uploadés
STORAGE_PATH=   ./fichiers/uploads
# Types de fichiers interdits (x-msdownload ->.exe , application/x-bat ->.bat, application/x-sh -> .sh)
FORBIDDEN_TYPES=application/x-msdownload,application/x-bat,application/x-sh
# Taille maximale du fichier (en octets) pour la validation métier
MAX_FILE_SIZE_BYTES=1073741824
# Durée d'expiration par défaut (en jours)
DEFAULT_EXPIRATION_DAYS=7
# Durée d'expiration maximale (en jours)
MAX_EXPIRATION_DAYS=7